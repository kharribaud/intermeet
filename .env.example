# Supabase
# Récupérez ces valeurs dans le dashboard Supabase : Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Clé service_role (secrète, serveur uniquement) — requise pour créer le bucket avatars
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
